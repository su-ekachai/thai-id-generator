{
  "name": "thai-id-generator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Educational Thai national ID number generator (13 digits). For learning the checksum algorithm only.",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/su-ekachai/thai-id-generator.git"
  },
  "homepage": "https://github.com/su-ekachai/thai-id-generator#readme",
  "bugs": {
    "url": "https://github.com/su-ekachai/thai-id-generator/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate-icons": "pwa-assets-generator --preset minimal-2023 public/icons/icon.svg"
  },
  "devDependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/noto-sans-thai-looped": "^5.2.3",
    "@tailwindcss/vite": "^4.0.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "tslog": "^4.10.2"
  }
}
